{
  "address": "isogrRJ6sEiktnfUY7QdZhDr5Sut3C8ER9HejjUqSZK",
  "metadata": {
    "name": "iso-xmm",
    "version": "0.1.0",
    "spec": "0.1.0",
    "description": "iso-xmm: oracle-anchored + CLMM Solana AMM (engines A1 ticks, B oracle-anchored maker). 1-byte instruction + account discriminators (not Anchor's 8-byte hash); all body scalars little-endian; index-bearing PDA seeds big-endian."
  },
