        { "name": "tick_array_lower", "writable": true, "signer": false },
        { "name": "tick_array_upper", "writable": true, "signer": false },
        { "name": "token_owner_0", "writable": true, "signer": false, "docs": ["user dst ATA (mint_0)"] },
